---
import ChevronDown from './ChevronDown.astro';
import { useTranslations, type Lang } from '../i18n/ui';

// Lightweight sort control for the concept & article indexes (and their
// category pages). Re-orders the cards inside every [data-sortgrid] on the page
// client-side and mirrors the choice into ?sort, the way the stacks catalog
// does.
//
// When `curatedLabel` is set (concepts, which carry an editorial `order`), the
// first option restores the server-rendered order and is the default — so the
// curated arrangement survives and a plain load never reflows. Without it
// (articles) the options are recent/name with `recent` as the default, which
// already matches the server render.
interface Props {
  lang: Lang;
  curatedLabel?: string;
}

const { lang, curatedLabel } = Astro.props;
const t = useTranslations(lang);
const options = [
  ...(curatedLabel ? [{ key: 'default', label: curatedLabel }] : []),
  { key: 'recent', label: t('sort.recent') },
  { key: 'alpha', label: t('sort.alpha') },
];
const summaryClass =
  'flex items-center gap-1.5 rounded-lg border border-[var(--aas-border)] bg-[var(--aas-panel)] px-3 py-1.5 text-sm text-[var(--aas-text)]';
const menuClass =
  'absolute right-0 z-10 mt-1 min-w-[12rem] overflow-y-auto rounded-lg border border-[var(--aas-border)] bg-[var(--aas-panel)] p-1 shadow-lg';
---

<div class="flex justify-end" data-sortbar data-default={options[0].key}>
  <details class="aas-dd">
    <summary class={summaryClass}>
      <span class="text-[var(--aas-muted)]">{t('sort.label')}:</span>
      <span data-sort-label>{options[0].label}</span>
      <ChevronDown class="text-[var(--aas-muted)]" />
    </summary>
    <ul class={menuClass}>
      {
        options.map((o, i) => (
          <li>
            <button
              type="button"
              data-sort={o.key}
              aria-current={i === 0 ? 'true' : 'false'}
              class="flex w-full items-center justify-between gap-2 rounded px-2 py-1.5 text-left text-sm hover:bg-[var(--aas-tint)] aria-[current=true]:font-semibold aria-[current=true]:text-[var(--aas-accent)]"
            >
              {o.label}
              <span data-check aria-hidden="true" class="opacity-0">
                ✓
              </span>
            </button>
          </li>
        ))
      }
    </ul>
  </details>
</div>

<script>
  const bar = document.querySelector<HTMLElement>('[data-sortbar]');
  if (bar) {
    const fallback = bar.dataset.default ?? 'recent';
    const buttons = Array.from(bar.querySelectorAll<HTMLButtonElement>('[data-sort]'));
    const labelEl = bar.querySelector<HTMLElement>('[data-sort-label]');
    const grids = Array.from(document.querySelectorAll<HTMLElement>('[data-sortgrid]'));
    // Snapshot the server-rendered (curated) order so it can be restored.
    const original = new Map(grids.map((g) => [g, Array.from(g.children) as HTMLElement[]]));

    const byName = (a: HTMLElement, b: HTMLElement) =>
      (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '');
    const comparator = (sort: string) =>
      sort === 'alpha'
        ? byName
        : (a: HTMLElement, b: HTMLElement) =>
            (b.dataset.date ?? '').localeCompare(a.dataset.date ?? '') || byName(a, b);

    const reorder = (grid: HTMLElement, cards: HTMLElement[]) =>
      cards.forEach((c) => grid.appendChild(c));

    const apply = (sort: string, write: boolean) => {
      for (const grid of grids) {
        const cards = original.get(grid) ?? [];
        reorder(grid, sort === 'default' ? cards : [...cards].sort(comparator(sort)));
      }
      for (const b of buttons) {
        const on = b.dataset.sort === sort;
        b.setAttribute('aria-current', String(on));
        b.querySelector<HTMLElement>('[data-check]')?.classList.toggle('opacity-0', !on);
        if (on && labelEl) labelEl.textContent = b.textContent?.replace('✓', '').trim() ?? '';
      }
      if (write) {
        const url = new URL(location.href);
        if (sort === fallback) url.searchParams.delete('sort');
        else url.searchParams.set('sort', sort);
        history.replaceState(null, '', url);
      }
    };

    for (const b of buttons) {
      b.addEventListener('click', () => {
        apply(b.dataset.sort ?? fallback, true);
        b.closest('details')?.removeAttribute('open');
      });
    }

    const known = new Set(buttons.map((b) => b.dataset.sort));
    const fromUrl = new URLSearchParams(location.search).get('sort');
    apply(fromUrl && known.has(fromUrl) ? fromUrl : fallback, false);
  }
</script>
