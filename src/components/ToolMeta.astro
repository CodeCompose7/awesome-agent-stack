---
import { pricingLabels, useTranslations, type Lang } from '../i18n/ui';
import { formatStars } from '../lib/github';

interface Props {
  lang: Lang;
  pricing: string[];
  license?: string;
  stars?: number | null;
  version?: string | null;
  released?: string | null; // YYYY-MM-DD of the latest release
  class?: string;
}

const { lang, pricing, license, stars, version, released, class: className } = Astro.props;
const t = useTranslations(lang);
const hasAny =
  pricing.length > 0 || license || typeof stars === 'number' || version || released;
---

{
  hasAny && (
    <div class:list={['flex flex-wrap items-center gap-1.5 text-xs', className]}>
      {typeof stars === 'number' && (
        <span class="inline-flex items-center gap-1 rounded-full border border-[var(--aas-border)] px-2 py-0.5 text-[var(--aas-muted)]">
          <span aria-hidden="true" class="text-amber-500">
            ★
          </span>
          {formatStars(stars)}
        </span>
      )}
      {version && (
        <span class="rounded-full border border-[var(--aas-border)] px-2 py-0.5 font-mono text-[var(--aas-muted)]">
          {version}
        </span>
      )}
      {released && (
        <span
          title={t('meta.released')}
          class="inline-flex items-center gap-1 rounded-full border border-[var(--aas-border)] px-2 py-0.5 text-[var(--aas-muted)]"
        >
          <span aria-hidden="true">↻</span>
          {released}
        </span>
      )}
      {pricing.map((p) => (
        <span class="rounded-full border border-[var(--aas-accent)] px-2 py-0.5 text-[var(--aas-accent)]">
          {pricingLabels[lang][p] ?? p}
        </span>
      ))}
      {license && (
        <span class="rounded-full border border-[var(--aas-border)] px-2 py-0.5 text-[var(--aas-muted)]">
          ⚖ {license}
        </span>
      )}
    </div>
  )
}
